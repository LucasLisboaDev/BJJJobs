# Copy to .env.test — use a DEDICATED test database (tests wipe all rows).

# Required: separate Postgres (local Docker, Railway test instance, or CI postgres service)
TEST_DATABASE_URL=postgresql://test:test@localhost:5433/jiujitsujobs_test

# Clerk (use your development instance keys for local E2E)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Optional: authenticated Playwright flows (create two Clerk users with password auth)
E2E_GYM_EMAIL=gym+e2e@yourdomain.com
E2E_GYM_PASSWORD=your-test-password
E2E_COACH_EMAIL=coach+e2e@yourdomain.com
E2E_COACH_PASSWORD=your-test-password

# App URL for Playwright
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Emails are mocked in API tests — these are optional for Vitest
RESEND_API_KEY=
RESEND_FROM_EMAIL=JiuJitsuJobs <onboarding@resend.dev>

# NEVER run tests against production DB. Override only if you know what you're doing:
# ALLOW_TEST_ON_MAIN_DB=1
